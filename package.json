{
  "name": "next-plate",
  "description": "A Next.js boilerplate",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "bunx -b next dev",
    "build": "bunx -b next build",
    "start": "bunx -b next start",
    "bundle": "bun -b ./scripts/bundle.ts",
    "db:seed": "bun -b ./scripts/db-seed.ts",
    "db:generate": "bunx -b drizzle-kit generate",
    "db:migrate": "bunx -b drizzle-kit migrate",
    "db:studio": "bunx -b drizzle-kit studio",
    "format": "biome format --write",
    "check": "biome check --write",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@libsql/client": "^0.17.3",
    "@orpc/server": "^1.14.6",
    "@tanstack/react-query": "^5.101.0",
    "better-auth": "^1.6.17",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@types/bun": "^1.3.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
